VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# In dev the app calls http://localhost:8081 — run "npm run debate-ai-proxy" in another terminal.
# For real AI, set OPENAI_API_KEY (used by debate-ai server).
# Production (Vercel): set DEBATE_AI_API_URL (server-side) to your Render API URL, e.g. https://rebutly-debate-ai-api.onrender.com — the app uses same-origin /api/debate-ai (no CORS).
# Optional: VITE_DEBATE_AI_SAME_ORIGIN=1 to use same-origin /api/debate-ai instead of 8081.